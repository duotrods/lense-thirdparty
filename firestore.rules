rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: user is authenticated AND has verified their email.
    // Applied to all data collections to prevent unverified accounts from
    // reading or writing operational data. (Phase 1 security fix)
    function isVerified() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    // Helper: get user's role from users collection
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Helper: get user's scheme (backward compatibility)
    function getUserScheme() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schemeId;
    }

    // Helper: get user's schemes array (multi-scheme support)
    function getUserSchemes() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schemeIds;
    }

    // Helper: check if user has access to a scheme
    function hasSchemeAccess(docSchemeIds) {
      let userSchemes = getUserSchemes();
      return userSchemes != null && docSchemeIds != null && userSchemes.hasAny(docSchemeIds);
    }

    // Helper: backward compatibility for single schemeId
    function hasOldSchemeAccess(docSchemeId) {
      let userSchemes = getUserSchemes();
      return userSchemes != null && docSchemeId != null && docSchemeId in userSchemes;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId ||
        getUserRole() == 'admin'
      );

      // SECURITY FIX: Self-update is restricted to safe fields only.
      // This prevents a user from escalating their own role to 'admin' or
      // toggling flags like 'canCreateAdmins' or 'isArchived'.
      // Admins can update any field on any user document.
      allow update: if isSignedIn() && (
        (request.auth.uid == userId &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['displayName', 'activeSchemeId', 'lastLogoutAt', 'lastLoginAt', 'emailVerified', 'updatedAt'])) ||
        getUserRole() == 'admin'
      );

      allow create: if isSignedIn();
      allow delete: if isSignedIn() && (request.auth.uid == userId || getUserRole() == 'admin');
    }

    // OTP codes - admin only
    match /otpCodes/{otpId} {
      allow read, write: if isSignedIn() && getUserRole() == 'admin';
    }

    // Client OTPs
    match /clientOTPs/{otpId} {
      allow write: if isSignedIn() && getUserRole() == 'admin';
      // SECURITY FIX: Split 'allow read: if true' into get vs list.
      // 'get' (single doc) is still public — needed for OTP validation during
      // signup before the user has a Firebase account.
      // 'list' (query all docs) is admin-only — prevents anyone from
      // enumerating all active OTP codes.
      allow get: if true;
      allow list: if isSignedIn() && getUserRole() == 'admin';
    }

    // CCTV Operator Access Codes (separate from clientOTPs)
    match /cctvOperatorOTPs/{codeId} {
      allow write: if isSignedIn() && getUserRole() == 'admin';
      allow get: if true;
      allow list: if isSignedIn() && getUserRole() == 'admin';
    }

    // Staff Invite Codes
    match /staffInviteCodes/{codeId} {
      allow write: if isSignedIn() && getUserRole() == 'admin';
      // SECURITY FIX: Same as clientOTPs — allow single-doc read for signup
      // validation but block listing all invite codes.
      allow get: if true;
      allow list: if isSignedIn() && getUserRole() == 'admin';
    }

    // Incident Reports
    match /incidentReports/{reportId} {
      allow create: if isVerified() && (
        getUserRole() == 'staff'
      );

      allow get: if isVerified() && (
        getUserRole() == 'admin' ||
        getUserRole() == 'staff' ||
        getUserRole() == 'liveoperator' ||
        (getUserRole() == 'client' && (
          hasSchemeAccess(resource.data.schemeIds) ||
          hasOldSchemeAccess(resource.data.schemeId)
        ))
      );

      allow list: if isVerified() && (
        getUserRole() == 'admin' ||
        getUserRole() == 'staff' ||
        getUserRole() == 'client' ||
        getUserRole() == 'liveoperator'
      );

      allow update, delete: if isVerified() && (
        getUserRole() == 'staff' || getUserRole() == 'admin'
      );
    }

    // CCTV Check Forms
    match /cctvCheckForms/{formId} {
      allow create: if isVerified() && (
        getUserRole() == 'staff'
      );

      allow get: if isVerified() && (
        getUserRole() == 'admin' ||
        getUserRole() == 'staff' ||
        (getUserRole() == 'client' && (
          hasSchemeAccess(resource.data.schemeIds) ||
          hasOldSchemeAccess(resource.data.schemeId)
        ))
      );

      allow list: if isVerified() && (
        getUserRole() == 'admin' ||
        getUserRole() == 'staff' ||
        getUserRole() == 'client' ||
        getUserRole() == 'cctvfaultoperator'
      );

      allow update, delete: if isVerified() && (
        getUserRole() == 'staff' || getUserRole() == 'admin'
      );
    }

    // Asset Damage Reports
    match /assetDamageReports/{reportId} {
      allow create: if isVerified() && (
        getUserRole() == 'staff'
      );

      allow get: if isVerified() && (
        getUserRole() == 'admin' ||
        getUserRole() == 'staff' ||
        (getUserRole() == 'client' && (
          hasSchemeAccess(resource.data.schemeIds) ||
          hasOldSchemeAccess(resource.data.schemeId)
        ))
      );

      allow list: if isVerified() && (
        getUserRole() == 'admin' ||
        getUserRole() == 'staff' ||
        getUserRole() == 'client'
      );

      allow update, delete: if isVerified() && (
        getUserRole() == 'staff' || getUserRole() == 'admin'
      );
    }

    // Daily Occurrence Reports
    match /dailyOccurrenceReports/{reportId} {
      allow create: if isVerified() && (
        getUserRole() == 'staff'
      );

      allow get: if isVerified() && (
        getUserRole() == 'admin' ||
        getUserRole() == 'staff' ||
        (getUserRole() == 'client' && (
          (resource.data.schemeIds != null && getUserSchemes() != null &&
           resource.data.schemeIds.hasAny(getUserSchemes())) ||
          hasOldSchemeAccess(resource.data.schemeId)
        ))
      );

      allow list: if isVerified() && (
        getUserRole() == 'admin' ||
        getUserRole() == 'staff' ||
        getUserRole() == 'client'
      );

      allow update, delete: if isVerified() && (
        getUserRole() == 'staff' || getUserRole() == 'admin'
      );
    }

    // CCTV Faults Reports
    match /cctvFaultsReports/{reportId} {
      allow create: if isVerified() && (
        getUserRole() == 'staff'
      );

      allow get: if isVerified() && (
        getUserRole() == 'admin' ||
        getUserRole() == 'staff' ||
        getUserRole() == 'cctvfaultoperator' ||
        (getUserRole() == 'client' && (
          hasSchemeAccess(resource.data.schemeIds) ||
          hasOldSchemeAccess(resource.data.schemeId)
        ))
      );

      allow list: if isVerified() && (
        getUserRole() == 'admin' ||
        getUserRole() == 'staff' ||
        getUserRole() == 'client' ||
        getUserRole() == 'cctvfaultoperator'
      );

      allow update: if isVerified() && (
        getUserRole() == 'staff' || getUserRole() == 'admin' ||
        (getUserRole() == 'client' &&
          hasSchemeAccess(resource.data.schemeIds) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['clientAcknowledged', 'acknowledgedAt', 'updatedAt'])
        ) ||
        (getUserRole() == 'cctvfaultoperator' &&
          (hasSchemeAccess(resource.data.schemeIds) ||
           getUserScheme() == resource.data.schemeId ||
           (resource.data.schemeIds != null && getUserScheme() != null && getUserScheme() in resource.data.schemeIds)) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['clientAcknowledged', 'clientNote', 'clientNotes', 'acknowledgedAt', 'updatedAt'])
        )
      );

      allow delete: if isVerified() && (
        getUserRole() == 'staff' || getUserRole() == 'admin'
      );
    }

    // CCTV Uploads
    match /cctvUploads/{uploadId} {
      allow create: if isVerified() && (
        getUserRole() == 'staff'
      );

      allow get: if isVerified() && (
        getUserRole() == 'admin' ||
        getUserRole() == 'staff' ||
        (getUserRole() == 'client' && (
          hasSchemeAccess(resource.data.schemeIds) ||
          hasOldSchemeAccess(resource.data.scheme)
        ))
      );

      allow list: if isVerified() && (
        getUserRole() == 'admin' ||
        getUserRole() == 'staff' ||
        getUserRole() == 'client'
      );

      allow update, delete: if isVerified() && (
        getUserRole() == 'staff' || getUserRole() == 'admin'
      );
    }

    // Activities (for notice board)
    match /activities/{activityId} {
      allow create: if isVerified() && (
        getUserRole() == 'staff'
      );
      allow read: if isVerified() && (
        getUserRole() == 'admin' ||
        getUserRole() == 'staff'
      );
      allow update, delete: if isVerified() && (
        getUserRole() == 'staff'
      );
    }

    // Counters (for reference ID generation)
    match /counters/{counterId} {
      allow read, write: if isVerified() && (
        getUserRole() == 'staff'
      );
    }

    // Audit Logs
    match /auditLogs/{logId} {
      allow create: if isVerified() && getUserRole() == 'admin';
      allow read: if isVerified() && getUserRole() == 'admin';
    }

    // Login Logs (audit trail of who signed in and when)
    // Any authenticated user can create their own login entry.
    // isSignedIn() used (not isVerified()) so the log is captured even if the
    // user hasn't verified their email yet — keeping the audit trail complete.
    // Only admins can read. TTL auto-deletes after 15 days.
    match /loginLogs/{logId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && getUserRole() == 'admin';
    }

    // Scheme Stats (running totals — vehicles dispatched, etc.)
    match /schemeStats/{schemeId} {
      allow get: if isVerified() && (
        getUserRole() == 'admin' ||
        getUserRole() == 'staff' ||
        (getUserRole() == 'client' &&
          getUserSchemes() != null && schemeId in getUserSchemes())
      );
      allow write: if isVerified() && (
        getUserRole() == 'staff' || getUserRole() == 'admin'
      );
    }

    // CCTV Uptime Cache (computed summaries, shared across users, 15-min TTL)
    match /cctvUptimeCache/{docId} {
      allow read, write: if isVerified();
    }

    // Collection count cache (computed dashboard totals, shared, 15-min TTL)
    match /collectionStatsCache/{docId} {
      allow read, write: if isVerified();
    }

    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
